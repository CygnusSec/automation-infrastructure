# Terraform input variables passed through environment variables.
#
# Copy this file to .env.terraform if you prefer environment variables for
# secrets or simple scalar values. Keep complex values such as maps/lists in
# envs/vcenter/*.auto.tfvars unless CI/CD requires otherwise.

TF_VAR_vsphere_server=
TF_VAR_vsphere_user=
TF_VAR_vsphere_password=
TF_VAR_allow_unverified_ssl=true
TF_VAR_datacenter=Datacenter
TF_VAR_host=
TF_VAR_datastore=
TF_VAR_network=
TF_VAR_template_name=

# Complex values can be passed as JSON when needed.
TF_VAR_host_datastore_map={"x.x.x.15":"datastore1 (5)","x.x.x.16":"datastore1 (4)","x.x.x.17":"datastore1 (3)","x.x.x.18":"datastore1 (2)"}
