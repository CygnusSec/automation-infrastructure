# Docker Compose and runtime image settings.
#
# Copy this file to .env.compose when you need to override the runtime image,
# Terraform version, or offline bundle image behavior.

TERRAFORM_IMAGE=terraform-vmware-vcenter-runtime:1.8.5
TERRAFORM_VERSION=1.8.5

# If RUNTIME_IMAGE is set, the offline bundle script pulls and packages it.
# If RUNTIME_IMAGE is empty, the offline bundle script builds LOCAL_RUNTIME_IMAGE.
RUNTIME_IMAGE=
LOCAL_RUNTIME_IMAGE=terraform-vmware-vcenter-runtime:1.8.5
