FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get upgrade -y \
    && apt-get install -y --no-install-recommends \
      ansible \
      dnsutils \
      iputils-ping \
      net-tools \
      openssh-client \
      sshpass \
      telnet \
      traceroute \
      vim \
      wget \
    && rm -rf /var/lib/apt/lists/*
