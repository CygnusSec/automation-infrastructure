# Ansible runtime image.
# Set RUNTIME_IMAGE to pull an image from a registry.
# Leave RUNTIME_IMAGE empty to build/use LOCAL_RUNTIME_IMAGE from build/dockerfile.
RUNTIME_IMAGE=
LOCAL_RUNTIME_IMAGE=

# Runtime wrapper.
# Relative path under Ansible/ to the optional extra vars file with secrets.
ANSIBLE_CONTROL_OFFLINE=
ANSIBLE_INVENTORY_SECRET_VARS=

# SSH connection.
ANSIBLE_SSH_USER=
ANSIBLE_SSH_PRIVATE_KEY_FILE=
ANSIBLE_BECOME=
ANSIBLE_BECOME_METHOD=

# Inventory hosts.
# Manager 1 is enabled by default in inventories/customer-a/hosts.
ANSIBLE_MANAGER_1_HOST=
ANSIBLE_MANAGER_1_ADVERTISE_ADDR=

# App worker examples are commented in inventories/customer-a/hosts.
# Uncomment those hosts there before setting these values.
ANSIBLE_APP_WORKER_1_HOST=
ANSIBLE_APP_WORKER_1_ADVERTISE_ADDR=
ANSIBLE_APP_WORKER_2_HOST=
ANSIBLE_APP_WORKER_2_ADVERTISE_ADDR=
ANSIBLE_APP_WORKER_3_HOST=
ANSIBLE_APP_WORKER_3_ADVERTISE_ADDR=

# Data worker examples are commented in inventories/customer-a/hosts.
# Uncomment those hosts there before setting these values.
ANSIBLE_DATA_WORKER_1_HOST=
ANSIBLE_DATA_WORKER_1_ADVERTISE_ADDR=
ANSIBLE_DATA_WORKER_2_HOST=
ANSIBLE_DATA_WORKER_2_ADVERTISE_ADDR=

# Target OS validation.
ANSIBLE_TARGET_OS_FAMILY=
ANSIBLE_TARGET_DISTRIBUTION=

# Prerequisite role.
ANSIBLE_PREREQUISITE_DISABLE_SWAP=
ANSIBLE_PREREQUISITE_DISABLE_UFW=
ANSIBLE_PREREQUISITE_TIMEZONE=
ANSIBLE_PREREQUISITE_INSTALL_FROM_LOCAL_REPO=
ANSIBLE_PREREQUISITE_REPO_SOURCE=
ANSIBLE_PREREQUISITE_REPO_DEST=

# Docker role.
ANSIBLE_DOCKER_INSTALL_FROM_LOCAL_REPO=
ANSIBLE_DOCKER_REPO_SOURCE=
ANSIBLE_DOCKER_REPO_DEST=

# Zabbix agent role.
# The control machine is the Zabbix server; set this to the control machine IP
# or DNS name reachable from the target hosts.
ANSIBLE_ZABBIX_AGENT_ENABLED=
ANSIBLE_ZABBIX_SERVER_HOST=
ANSIBLE_ZABBIX_SERVER_ACTIVE=
ANSIBLE_ZABBIX_AGENT_HOSTNAME=
ANSIBLE_ZABBIX_AGENT_INSTALL_FROM_LOCAL_REPO=
ANSIBLE_ZABBIX_AGENT_REPO_SOURCE=
ANSIBLE_ZABBIX_AGENT_REPO_DEST=
# Must be valid YAML, for example: '[zabbix-agent]' or '[zabbix-agent2]'
ANSIBLE_ZABBIX_AGENT_PACKAGES=
ANSIBLE_ZABBIX_AGENT_SERVICE_NAME=
ANSIBLE_ZABBIX_AGENT_CONFIG_FILE=

# Hostname role.
ANSIBLE_HOSTNAME_MANAGE=
ANSIBLE_HOSTNAME_VALUE=
ANSIBLE_HOSTNAME_DOMAIN=

# Network role.
# ANSIBLE_NETWORK_DNS_SERVERS must be valid YAML, for example:
# '[192.168.1.1, 8.8.8.8]'
ANSIBLE_NETWORK_MANAGE=
ANSIBLE_NETWORK_INTERFACE=
ANSIBLE_NETWORK_IPV4_ADDRESS=
ANSIBLE_NETWORK_IPV4_PREFIX_LENGTH=
ANSIBLE_NETWORK_IPV4_GATEWAY=
ANSIBLE_NETWORK_DNS_SERVERS=

# Docker Swarm role.
ANSIBLE_DOCKER_SWARM_ENABLED=
ANSIBLE_DOCKER_SWARM_MANAGER_GROUP=
ANSIBLE_DOCKER_SWARM_WORKER_GROUP=
ANSIBLE_DOCKER_SWARM_LISTEN_ADDR=
ANSIBLE_DOCKER_SWARM_PORT=
ANSIBLE_DOCKER_SWARM_FORCE_RESET=
ANSIBLE_DOCKER_SWARM_MANAGER_ADDR=
ANSIBLE_DOCKER_SWARM_MANAGE_IPTABLES=
ANSIBLE_DOCKER_SWARM_IPTABLES_SOURCE_CIDR=
ANSIBLE_DOCKER_SWARM_MANAGE_ENCRYPTED_OVERLAY_ESP=

# Docker Swarm published service ports.
# Must be valid YAML, for example:
# '[{port: 80, protocol: tcp}, {port: 443, protocol: tcp}]'
ANSIBLE_DOCKER_SWARM_SERVICE_PORTS=

# Docker Swarm node labels.
# Must be valid YAML, for example:
# '{swarm_app_workers: {workload: app, disk: ssd}, swarm_data_workers: {workload: data, disk: hdd}}'
ANSIBLE_DOCKER_SWARM_GROUP_LABELS=

# Host-level labels for a single inventory host.
# Must be valid YAML, for example:
# '{rack: rack-a}'
ANSIBLE_DOCKER_SWARM_NODE_LABELS=
